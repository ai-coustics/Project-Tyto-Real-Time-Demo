# Copy to .env (or just export these) before running the demos.

# ai-coustics SDK license key, used by every demo to run Tyto.
# Get one at https://developers.ai-coustics.com
AIC_SDK_LICENSE=

# OpenAI API key, used only by the full voice agent (examples/voice_agent.py).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
