# Copy to .env (or just export these) before running the demos.

# ai-coustics SDK license key, used by every demo to run Tyto.
# Get one at https://developers.ai-coustics.com
AIC_SDK_LICENSE=

# OpenAI API key, used by the full voice agent (examples/voice_agent.py) and
# every realtime backend (examples/web, examples/pipecat, examples/livekit).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# LiveKit credentials, used only by the LiveKit backend (examples/livekit).
# Get them from a free project at https://cloud.livekit.io (or self-host).
# The agent worker reads all of these; the token server reads only the LIVEKIT_* ones.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
